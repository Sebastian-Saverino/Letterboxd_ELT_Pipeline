
# MinIO (Object Storage)
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
MINIO_BUCKET_RAW=raw


# Postgres - Metadata DB
POSTGRES_META_HOST=postgres-meta
POSTGRES_META_USER=postgres
POSTGRES_META_PASSWORD=password
POSTGRES_META_DB=letterboxd_metadata
POSTGRES_META_PORT=5432


# Postgres - Warehouse DB

POSTGRES_WAREHOUSE_USER=user
POSTGRES_WAREHOUSE_PASSWORD=pass
POSTGRES_WAREHOUSE_DB=letterboxd_warehouse
POSTGRES_WAREHOUSE_PORT=5432
POSTGRES_WAREHOUSE_HOST=postgres-warehouse


# FastAPI App

API_HOST=0.0.0.0
API_PORT=8000
API_ENV=local


# dbt

DBT_TARGET=dev
DBT_PROFILES_DIR=/usr/app


# Metabase
METABASE_APP_DB=metabaseappdb
METABASE_APP_USER=metabase
METABASE_APP_PASSWORD=yourpassword


# Airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW_FERNET_KEY=replace_with_a_valid_fernet_key
AIRFLOW_WEBSERVER_SECRET_KEY=replace_with_a_long_random_string
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me
AIRFLOW_ADMIN_FIRSTNAME=Letterboxd
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
LETTERBOXD_PIPELINE_SCHEDULE=0 2 * * *
LETTERBOXD_INGESTION_FILE_GLOB=*.csv
LETTERBOXD_RAW_PREFIX=letterboxd/
